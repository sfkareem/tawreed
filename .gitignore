# ----- Application runtime data (per user, never committed) -----
# Tawreed stores user config + DB in %LOCALAPPDATA%/Tawreed on Windows,
# ~/.tawreed on Linux/macOS. These don't live in the repo, but the
# PyInstaller build drops artefacts in build/ and dist/.

# ----- Local agent scratch -----
.agents/

# ----- Secrets (per host security policy) -----
.env
.env.*
!.env.example
*.key
*.pem
*credentials*
*secrets*
secret.*
service-account*.json
.ai_config.json
*.local.json
# config.json is the live user config (Lives at ~/.tawreed/config.json
# at runtime, but ignore the bare filename as belt-and-braces — never
# commit a developer's local config.json by accident).
config.json

# ----- Logs -----
*.log
logs/
