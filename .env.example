# Tawreed — environment variable template.
#
# Copy this file to `.env` (which is gitignored) if you want a local
# override. On Windows, the equivalent is `setx VAR value` from a
# shell, or set them in System → Environment Variables.
#
# NOTE: Tawreed does NOT actually read API keys from the environment.
# All credentials are entered in the GUI Settings page and stored in
# `~/.tawreed/config.json` (or `%USERPROFILE%\.tawreed\config.json` on
# Windows). This file exists for security-tooling compliance (e.g.
# `gitleaks` looks for it) and to document the supported providers.

# ----- LLM provider keys (informational only) -----
# OPENAI_API_KEY=***     # OpenAI: https://platform.openai.com/api-keys
# ANTHROPIC_API_KEY=***  # Anthropic Claude: https://console.anthropic.com/
# GOOGLE_API_KEY=***     # Google Gemini: https://aistudio.google.com/apikey

# ----- Tawreed runtime -----
# TAWREED_LOG_LEVEL=INFO           # DEBUG, INFO, WARNING, ERROR
# TAWREED_LOG_DIR=~/.tawreed/logs  # override the log directory

# ----- State location override (advanced) -----
# By default, Tawreed stores all state at ~/.tawreed/ (cross-platform).
# Override only if you have a specific reason (e.g. a corporate policy
# that requires state to live in a different directory).
# TAWREED_HOME=/custom/path
